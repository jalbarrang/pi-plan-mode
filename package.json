{
  "name": "@dreki-gg/pi-plan-mode",
  "version": "0.39.0",
  "description": "Two-phase planning workflow for pi — plan with claude-opus-4-6:medium, execute with gpt-5.5:low, with file-based plan-ledger handoff (default .taskman/plans/, configurable via .taskmanrc)",
  "keywords": [
    "pi-package"
  ],
  "author": "Juan Albarran <jalbarrandev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalbarrang/pi-plan-mode.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.17.0",
  "bin": {
    "pi-plan-mode": "bin/clean-plans.js"
  },
  "files": [
    "extensions",
    "!extensions/plan-mode/__tests__",
    "skills",
    "bin",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint extensions bin",
    "format": "oxfmt --write extensions bin",
    "format:check": "oxfmt --check extensions bin",
    "test": "bun test extensions/plan-mode/__tests__"
  },
  "pi": {
    "extensions": [
      "./extensions/plan-mode"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@dreki-gg/pi-command-sandbox": "^0.4.2",
    "@dreki-gg/taskman": "^0.8.0",
    "effect": "^3.22.0",
    "typebox": "1.3.7"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.82.0",
    "@types/node": "26",
    "bun-types": "latest",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "typescript": "^7.0.2",
    "@earendil-works/pi-coding-agent": "^0.82.0",
    "@earendil-works/pi-tui": "^0.82.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
